{
  "name": "backend_marketplace_app",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --watch ./index.ts",
    "test": "bun run test:unit && bun run test:e2e",
    "test:unit": "bunx concurrently --names order,payment,product,user --prefix \"[{name}]\" --prefix-colors blue,green,magenta,cyan \"bun run test:order\" \"bun run test:payment\" \"bun run test:product\" \"bun run test:user\"",
    "test:order": "bun test --env-file .env.test src/test/order/domain src/test/order/application",
    "test:payment": "bun test --env-file .env.test src/test/payment/domain src/test/payment/application",
    "test:product": "bun test --env-file .env.test src/test/product/domain src/test/product/application",
    "test:user": "bun test --env-file .env.test src/test/user/domain src/test/user/application",
    "test:e2e": "bun test --env-file .env.test src/test/e2e",
    "test:dots": "bun run test:unit:dots && bun run test:e2e:dots",
    "test:unit:dots": "bunx concurrently --names order,payment,product,user --prefix \"[{name}]\" --prefix-colors blue,green,magenta,cyan \"bun run test:order:dots\" \"bun run test:payment:dots\" \"bun run test:product:dots\" \"bun run test:user:dots\"",
    "test:order:dots": "bun test --env-file .env.test --dots src/test/order/domain src/test/order/application",
    "test:payment:dots": "bun test --env-file .env.test --dots src/test/payment/domain src/test/payment/application",
    "test:product:dots": "bun test --env-file .env.test --dots src/test/product/domain src/test/product/application",
    "test:user:dots": "bun test --env-file .env.test --dots src/test/user/domain src/test/user/application",
    "test:e2e:dots": "bun test --env-file .env.test --dots src/test/e2e",
    "test:watch": "bun test --watch --env-file .env.test",
    "test:coverage": "bun test --coverage --env-file .env.test",
    "format": "bunx --bun @biomejs/biome format --write",
    "lint": "bunx --bun @biomejs/biome lint --write"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@types/bun": "latest",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mongoose": "^5.11.97",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "concurrently": "^9.2.1",
    "lint-staged": "^15.5.2",
    "mongodb-memory-server": "^11.0.1",
    "morgan": "^1.10.1",
    "simple-git-hooks": "^2.13.0",
    "supertest": "^7.2.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "simple-git-hooks": {
    "pre-commit": "export PATH=$HOME/.bun/bin:$PATH && bunx lint-staged && bun run test",
    "pre-push": "export PATH=$HOME/.bun/bin:$PATH && bun run test"
  },
  "lint-staged": {
    "*.{ts,tsx,js}": [
      "bunx --bun @biomejs/biome format --write",
      "bunx --bun @biomejs/biome lint --write"
    ]
  }
}
