{
  "name": "backend_marketplace_app",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --watch ./index.ts",
    "test": "bun run scripts/run-tests.ts all",
    "test:unit": "bun run scripts/run-tests.ts unit",
    "test:e2e": "bun run scripts/run-tests.ts e2e",
    "test:dots": "bun run scripts/run-tests.ts all --dots",
    "test:unit:dots": "bun run scripts/run-tests.ts unit --dots",
    "test:e2e:dots": "bun run scripts/run-tests.ts e2e --dots",
    "test:watch:unit": "bun run scripts/run-tests.ts unit --watch",
    "test:watch:e2e": "bun run scripts/run-tests.ts e2e --watch",
    "test:watch": "bun test --watch --env-file .env.test",
    "test:coverage": "bun test --coverage --env-file .env.test",
    "format": "bunx --bun @biomejs/biome format --write",
    "lint": "bunx --bun @biomejs/biome lint --write"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@types/bun": "latest",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mongoose": "^5.11.97",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "lint-staged": "^15.5.2",
    "mongodb-memory-server": "^11.0.1",
    "morgan": "^1.10.1",
    "simple-git-hooks": "^2.13.0",
    "supertest": "^7.2.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "simple-git-hooks": {
    "pre-commit": "bun run scripts/run-hook.ts pre-commit",
    "pre-push": "bun run scripts/run-hook.ts pre-push"
  },
  "lint-staged": {
    "*.{ts,tsx,js}": [
      "bunx --bun @biomejs/biome format --write",
      "bunx --bun @biomejs/biome lint --write"
    ]
  }
}
