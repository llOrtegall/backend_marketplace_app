{
  "name": "backend_marketplace_app",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --watch ./index.ts",
    "format": "bunx --bun @biomejs/biome format --write",
    "lint": "bunx --bun @biomejs/biome lint --write"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@types/bun": "latest",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.5.0",
    "lint-staged": "^15.5.2",
    "morgan": "^1.10.1",
    "simple-git-hooks": "^2.13.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "simple-git-hooks": {
    "pre-commit": "export PATH=$HOME/.bun/bin:$PATH && bunx lint-staged"
  },
  "lint-staged": {
    "*.{ts,tsx,js}": ["bunx --bun @biomejs/biome format --write", "bunx --bun @biomejs/biome lint --write"]
  }
}
